<%- include('../partials/head') %>
</head>
<body class="min-h-screen bg-gradient-to-br from-[#667eea] to-[#764ba2] font-sans text-[#333]">

    <%- include('../partials/nav') %>

    <header class="bg-gradient-to-r from-[#FF5A5F] to-[#E61E4D] text-white text-center py-8 px-4 shadow-md">
        <h1 class="text-4xl font-bold tracking-wide">Add Your Home to Airbnb</h1>
    </header>

    <main class="max-w-xl mx-auto mt-8 mb-8 p-8 bg-white rounded-xl shadow-lg">

        <p class="text-[0.95rem] text-[#555] mb-6">
            Fill in the details below to list your property on Airbnb.
        </p>

        <form action="/host/add-home" method="POST" class="flex flex-col gap-6">

            <div class="flex flex-col gap-2">
                <label for="houseName" class="text-[1.1rem] font-semibold text-[#333]">House Name</label>
                <input type="text" id="houseName" name="houseName" placeholder="e.g. Cozy Beach Cottage" required
                    class="px-3 py-3 border-2 border-[#ddd] rounded-lg text-base font-sans focus:outline-none focus:border-[#FF5A5F] focus:ring-2 focus:ring-[#FF5A5F]/20 transition-colors duration-300">
            </div>

            <div class="flex flex-col gap-2">
                <label for="location" class="text-[1.1rem] font-semibold text-[#333]">Location</label>
                <input type="text" id="location" name="location" placeholder="e.g. Malibu, California" required
                    class="px-3 py-3 border-2 border-[#ddd] rounded-lg text-base font-sans focus:outline-none focus:border-[#FF5A5F] focus:ring-2 focus:ring-[#FF5A5F]/20 transition-colors duration-300">
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="flex flex-col gap-2">
                    <label for="price" class="text-[1.1rem] font-semibold text-[#333]">Price per Night</label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[#888] font-semibold">$</span>
                        <input type="number" id="price" name="price" placeholder="0" min="0" required
                            class="w-full pl-7 pr-3 py-3 border-2 border-[#ddd] rounded-lg text-base font-sans focus:outline-none focus:border-[#FF5A5F] focus:ring-2 focus:ring-[#FF5A5F]/20 transition-colors duration-300">
                    </div>
                </div>

                <div class="flex flex-col gap-2">
                    <label for="rating" class="text-[1.1rem] font-semibold text-[#333]">Rating</label>
                    <input type="number" id="rating" name="rating" placeholder="e.g. 4.8" min="0" max="5" step="0.1" required
                        class="px-3 py-3 border-2 border-[#ddd] rounded-lg text-base font-sans focus:outline-none focus:border-[#FF5A5F] focus:ring-2 focus:ring-[#FF5A5F]/20 transition-colors duration-300">
                </div>
            </div>

            <div class="flex flex-col gap-2">
                <label for="photoUrl" class="text-[1.1rem] font-semibold text-[#333]">Photo URL</label>
                <input type="url" id="photoUrl" name="photoUrl" placeholder="https://example.com/photo.jpg"
                    class="px-3 py-3 border-2 border-[#ddd] rounded-lg text-base font-sans focus:outline-none focus:border-[#FF5A5F] focus:ring-2 focus:ring-[#FF5A5F]/20 transition-colors duration-300">
            </div>

            <input type="submit" value="Add Home"
                class="bg-gradient-to-r from-[#FF5A5F] to-[#E61E4D] text-white py-3 px-6 border-none rounded-lg text-[1.1rem] font-semibold cursor-pointer shadow-md hover:-translate-y-0.5 hover:shadow-lg active:translate-y-0 transition-all duration-300">

        </form>

    </main>

</body>
</html>