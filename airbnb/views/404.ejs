<%- include('./partials/head') %>
</head>
<body class="min-h-screen bg-gradient-to-br from-[#667eea] to-[#764ba2] font-sans text-[#333]">

    <header class="bg-gradient-to-r from-[#FF5A5F] to-[#E61E4D] text-white text-center py-8 px-4 shadow-md">
        <h1 class="text-4xl font-bold tracking-wide">Airbnb</h1>
    </header>

    <main class="max-w-2xl mx-auto mt-12 mb-8 p-12 bg-white rounded-xl shadow-lg text-center">

        <div class="text-6xl mb-4">🔍</div>

        <div class="text-8xl font-bold text-[#FF5A5F] leading-none tracking-tighter mb-2">
            404
        </div>

        <h2 class="text-2xl font-bold text-[#333] mb-4">Page Not Found</h2>

        <hr class="border-none border-t border-[#f0f0f0] w-3/5 mx-auto my-6">

        <p class="text-base text-[#666] mb-6 max-w-sm mx-auto">
            The page you are looking for doesn't exist or may have been moved.
        </p>

        <a href="/"
           class="inline-block bg-gradient-to-r from-[#FF5A5F] to-[#E61E4D] text-white px-8 py-3 rounded-lg text-base font-semibold shadow-md hover:-translate-y-0.5 hover:shadow-lg transition-all duration-300 no-underline">
            Go back to Home
        </a>

    </main>

</body>
</html>