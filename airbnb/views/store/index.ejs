<%- include ('../partials/head') %>
</head>
<body class="min-h-screen bg-gradient-to-br from-[#667eea] to-[#764ba2] font-sans text-[#333]">

    <%- include('../partials/nav') %>
    <header class="bg-gradient-to-r from-[#FF5A5F] to-[#E61E4D] text-white text-center py-8 px-4 shadow-md">
        <h1 class="text-4xl font-bold tracking-wide">Welcome to Airbnb</h1>
    </header>

    <main class="max-w-7xl mx-auto mt-8 mb-8 p-8 bg-white rounded-xl shadow-lg text-center">
        <p class="text-xl text-[#555] my-6">
            Discover amazing homes and experiences around the world
        </p>
        <a href="/host/add-home"
           class="inline-block bg-gradient-to-r from-[#FF5A5F] to-[#E61E4D] text-white px-8 py-4 rounded-lg mt-4 text-lg font-semibold shadow-md hover:-translate-y-0.5 hover:shadow-lg transition-all duration-300 no-underline">
            Add Home
        </a>

        <p class="text-sm font-semibold text-[#aaa] uppercase tracking-widest mt-10 mb-4 text-left">
            Registered Homes
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 text-left">
            <% registeredHomes.forEach(home => { %>
                <div class="bg-white rounded-2xl overflow-hidden shadow-md border border-gray-200 hover:shadow-xl transition duration-300">

                    <!-- Image -->
                    <div class="relative">
                        <img
                            src="<%= home.photoUrl %>"
                            alt="<%= home.houseName %>"
                            class="w-full h-64 object-cover"
                        >

                        <% if (home.rating) { %>
                            <div class="absolute top-3 right-3 bg-white px-3 py-1 rounded-full shadow text-sm font-medium">
                                ⭐ <%= home.rating %>
                            </div>
                        <% } %>
                    </div>

                    <!-- Content -->
                    <div class="p-5">

                        <!-- House Name -->
                        <h3 class="text-xl font-bold text-gray-800 mb-3">
                            <%= home.houseName %>
                        </h3>

                        <!-- Location -->
                        <div class="flex items-center text-gray-500 mb-4">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-4 h-4 mr-2"
                                fill="currentColor"
                                viewBox="0 0 24 24">
                                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                            </svg>

                            <span><%= home.location %></span>
                        </div>

                        <!-- Footer -->
                        <div class="border-t pt-4">

                            <!-- Price -->
                            <div class="mb-4">
                                <span class="text-2xl font-bold text-gray-900">
                                    $<%= home.price %>
                                </span>

                                <span class="text-gray-500 text-sm">
                                    / night
                                </span>
                            </div>

                            <!-- Buttons -->
                            <div class="grid grid-cols-2 gap-3">

                                <a
                                    href="/home-details/<%= home.id %>"
                                    class="text-center bg-[#ebd512] text-black py-3 rounded-lg font-medium hover:bg-[#fff23c] transition">
                                    Details
                                </a>

                                <%- include('../partials/favourites', { home: home }) %>

                            </div>

                        </div>

                    </div>

                </div>
            <% }); %>
        </div>

    </main>

</body>
</html>