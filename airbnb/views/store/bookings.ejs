    <%- include ('../partials/head') %>
    </head>
    <body class="min-h-screen bg-gradient-to-br from-[#667eea] to-[#764ba2] font-sans text-[#333]">

        <%- include('../partials/nav') %>
        
        <header class="bg-gradient-to-r from-[#FF5A5F] to-[#E61E4D] text-white text-center py-8 px-4 shadow-md">
            <h1 class="text-4xl font-bold tracking-wide">Welcome to Airbnb</h1>
        </header>

        <main class="max-w-5xl mx-auto mt-8 mb-8 p-8 bg-white rounded-xl shadow-lg text-center">
            <p class="text-xl text-[#555] my-6">
                My Bookings
            </p>
            <p class="text-sm font-semibold text-[#aaa] uppercase tracking-widest mt-10 mb-4 text-left">
                Booked Homes
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 text-left">
                <% registeredHomes.forEach(house => { %>
                    <div class="bg-white rounded-2xl overflow-hidden shadow-md border border-gray-200 hover:shadow-xl transition duration-300">

                        <!-- Image -->
                        <div class="relative">
                            <img
                                src="<%= house.photoUrl %>"
                                alt="<%= house.houseName %>"
                                class="w-full h-64 object-cover"
                            >

                            <% if (house.rating) { %>
                                <div class="absolute top-3 right-3 bg-white px-3 py-1 rounded-full shadow text-sm font-medium">
                                    ⭐ <%= house.rating %>
                                </div>
                            <% } %>
                        </div>

                        <!-- Content -->
                        <div class="p-5">

                            <!-- House Name -->
                            <h3 class="text-xl font-bold text-gray-800 mb-3">
                                <%= house.houseName %>
                            </h3>

                            <!-- Location -->
                            <div class="flex items-center text-gray-500 mb-4">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="w-4 h-4 mr-2"
                                    fill="currentColor"
                                    viewBox="0 0 24 24">
                                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                                </svg>

                                <span><%= house.location %></span>
                            </div>

                            <!-- Footer -->
                            <div class="border-t pt-4">

                                <!-- Price -->
                                <div class="mb-4">
                                    <span class="text-2xl font-bold text-gray-900">
                                        $<%= house.price %>
                                    </span>

                                    <span class="text-gray-500 text-sm">
                                        / night
                                    </span>
                                </div>

                                <!-- Buttons -->
                                <div class="grid grid-cols-2 gap-2">
                                    <button
                                        class="bg-[#ebd512] text-black px-4 py-2 rounded-lg hover:bg-[#fff23c]">
                                        Book Now
                                    </button>

                                    <a href="/home-details/<%= house.id %>"
                                        class="flex-1 text-center bg-[#FF5A5F] text-white py-2 rounded-lg font-medium hover:bg-[#E61E4D] transition">
                                        View
                                    </a>
                                </div>

                            </div>

                        </div>

                    </div>
                <% }); %>
            </div>
        </main>
    </body>
</html>